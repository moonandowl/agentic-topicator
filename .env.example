# Reference only: set each variable in your host dashboard (Railway, Render, etc.) or export in your shell.
# The app reads process environment variables only; it does not load this file.
#
# At least one required for the chosen model
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=

# Optional model overrides (defaults shown)
# OPENAI_MODEL=gpt-5.4-pro
# GOOGLE_MODEL=gemini-3.1-pro-preview
# ANTHROPIC_MODEL=claude-opus-4-6
# PERPLEXITY_MODEL=sonar-pro
# GROK_MODEL=grok-4-fast-reasoning

# Optional: when set, enables HTTP Basic Auth on all routes except /health (password only; username ignored)
AUTH_PASSWORD=
